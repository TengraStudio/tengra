# --- Tengra Project Gitignore ---

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Build Output
dist/
dist-electron/
release/*
!release/*.nsh
!release/.gitignore
release/win-unpacked/
release/linux-unpacked/
release/mac-unpacked/
release/*.exe
release/*.blockmap
release/*.yml
release/*.zip
release/*.dmg
release/*.AppImage
release/*.deb
release/*.rpm
out/
.next/
.nuxt/
.cache/
.serverless/
.fusebox/
/website/appendonlydir

# Rust / Native Artifacts
**/target/
**/*.pdb
**/*.o
**/*.obj
**/*.so
**/*.dylib
**/*.dll
**/*.exe
**/*.tmp
!src/native/bin/*.exe

# Environment & Secrets
.env
.env.*
!.env.example
*.key
*.pem
*.cert 
vitest-results.json

# IDEs & Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.user

# OS Specific
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Logs & Temporary Files
logs/
*.log
npm-debug.log*
yarn-debug.log*
pids/
*.pid
*.seed
*.pid.lock
/tmp/
/scratch/
/reports/
*.tmp.*
*.audit.json
*.dump.txt
FreshScan*.json
fresh_scan*.json
latest_scan*.json
FreshAnalysis*.json

# Test Results & Coverage
coverage/
.nyc_output/
*.lcov
vitest-results.json
vitest-results-renderer.json
stryker.log
stryker-results.json
.stryker-tmp/
benchmark-results.json
sbom.json

# TypeScript
*.tsbuildinfo
typings/

# Project Specific Ignored Artifacts
t_keys.txt
all_t_keys.txt
tmp-hardcoded.json
IPC_CHANNELS.md
.codex/SESSION_ENGINE.md
docs/changelog/i18n/.tr.translation.cache.json
docs/components_checklist.md
lint_errors.txt
fresh-lint.txt
fresh-analysis.txt
fresh-scan.json
fresh-scan-results.json

{
    "name": "tengra",
    "version": "1.0.0",
    "description": "Tengra - Your Personal AI Assistant",
    "main": "dist/main/main.js",
    "type": "commonjs",
    "scripts": {
        "dev": "set ELECTRON_RUN_AS_NODE= && set NODE_OPTIONS=--max-old-space-size=8192 && vite",
        "build": "tsc && npm run lint && vite build && node scripts/build-native.js",
        "build:check": "tsc --noEmit && vite build",
        "preview": "vite preview",
        "setup-build-env": "node scripts/setup-build-env.js",
        "preinstall": "node scripts/setup-build-env.js || true",
        "postinstall": "node scripts/setup-build-env.js || true",
        "install:native": "powershell -ExecutionPolicy Bypass -File scripts/install-native.ps1",
        "electron:dev": "set ELECTRON_RUN_AS_NODE= && set NODE_OPTIONS=--max-old-space-size=8192 && vite",
        "electron:build": "npm run build && electron-builder",
        "build:exe": "npm run build && electron-builder --win --x64",
        "build:exe:publish": "npm run build && electron-builder --win --x64 --publish=always",
        "test": "vitest run && vitest run --config vitest.config.renderer.ts",
        "test:unit": "vitest run",
        "test:renderer": "vitest run --config vitest.config.renderer.ts",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage && vitest run --coverage --config vitest.config.renderer.ts",
        "test:e2e": "playwright test",
        "lint": "set NODE_OPTIONS=--max-old-space-size=8192 && eslint .",
        "type-check": "tsc --noEmit",
        "changelog:migrate": "node scripts/changelog/migrate-from-markdown.cjs",
        "changelog:new": "node scripts/changelog/new-entry.cjs",
        "changelog:seed:de": "node scripts/changelog/seed-overrides.cjs --locale=de",
        "changelog:seed:all": "node scripts/changelog/seed-all-overrides.cjs",
        "changelog:auto:draft": "node scripts/changelog/generate-from-commits.cjs",
        "changelog:auto:apply": "node scripts/changelog/generate-from-commits.cjs --apply",
        "changelog:i18n:report": "node scripts/changelog/report-untranslated.cjs",
        "changelog:i18n:gate": "node scripts/changelog/report-untranslated.cjs --fail-on-threshold --threshold-file=docs/changelog/i18n/gate.thresholds.json",
        "changelog:translate:tr": "node scripts/changelog/translate-overrides.tr.cjs",
        "changelog:translate:locales": "node scripts/changelog/translate-overrides.locales.cjs",
        "changelog:polish:tr": "node scripts/changelog/manual-polish-tr.cjs",
        "changelog:build": "node scripts/changelog/build.cjs",
        "changelog:rss": "node scripts/changelog/generate-rss.cjs",
        "changelog:rss:test": "node scripts/changelog/test-rss.cjs",
        "changelog:validate": "node scripts/changelog/validate-quality.cjs",
        "changelog:sync": "npm run changelog:build && npm run changelog:validate",
        "i18n:quality": "node scripts/check-translation-quality.js",
        "lint:fix": "set NODE_OPTIONS=--max-old-space-size=8192 && eslint . --fix",
        "lint:boundaries": "node src/scripts/check-boundaries.js",
        "secrets:scan": "secretlint --secretlintignore .secretlintignore \"**/*\"",
        "secrets:detect": "detect-secrets scan --baseline .secrets.baseline",
        "secrets:audit": "detect-secrets audit .secrets.baseline",
        "secrets:update": "detect-secrets scan --baseline .secrets.baseline --update .secrets.baseline",
        "sbom": "npm sbom --sbom-format=cyclonedx --output-file=sbom.json",
        "audit:deps": "npm audit --audit-level=moderate",
        "audit:deps:gate": "node scripts/security/vuln-gate.cjs",
        "deps:audit:report": "node scripts/dependency-audit.cjs",
        "bundle:analyze": "bundlewatch --config .bundlewatch.config.json",
        "check-bundle": "node scripts/check-bundle-size.cjs",
        "audit:critical": "node scripts/audit-critical-priority.js",
        "metrics:code": "node scripts/code-metrics-report.cjs",
        "metrics:debt": "node scripts/technical-debt-report.cjs",
        "metrics:coverage": "node scripts/coverage-report.cjs",
        "naming:report": "node scripts/naming-conventions-report.cjs",
        "metrics:lint-typecheck": "node scripts/lint-typecheck-dashboard.cjs",
        "metrics:all": "npm run metrics:code && npm run metrics:coverage && npm run metrics:debt && npm run deps:audit:report",
        "docs:ipc": "node scripts/docs/generate-ipc-channels-doc.cjs",
        "docs:ipc:schemas": "node scripts/ipc/generate-schema-docs.cjs",
        "docs:mcp": "node scripts/docs/generate-mcp-docs.cjs",
        "mcp:new-server": "node scripts/mcp/generate-server.cjs",
        "db:migrate:plan": "node scripts/db/migration-cli.cjs migrate",
        "db:migrate:rollback": "node scripts/db/migration-cli.cjs rollback",
        "perf:startup": "node scripts/benchmark-startup.js",
        "perf:memory": "node scripts/benchmark-memory.js",
        "perf:ipc": "node scripts/benchmark-ipc-latency.cjs",
        "perf:db": "node scripts/benchmark-db-performance.cjs",
        "perf:dashboard": "node scripts/performance-dashboard.cjs",
        "perf:ci": "npm run perf:startup && npm run bundle:analyze",
        "test:mutation": "npx stryker run",
        "format": "node scripts/format-changed.js --write",
        "format:check": "node scripts/format-changed.js",
        "format:all": "npx prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
        "format:all:check": "npx prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
        "gh:cleanup": "node scripts/cleanup-workflow-runs.js",
        "gh:cleanup:all": "node scripts/cleanup-workflow-runs.js --status=all --older-than=7",
        "gh:cleanup:dry": "node scripts/cleanup-workflow-runs.js --dry-run",
        "prepare": "husky install || true"
    },
    "keywords": [
        "ai",
        "chat",
        "ollama",
        "electron",
        "copilot",
        "tengra"
    ],
    "author": "",
    "license": "GPL-3.0",
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@eslint/js": "^9.39.3",
        "@playwright/test": "^1.58.2",
        "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^20.19.33",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.2.0",
        "@types/react-file-icon": "^1.0.4",
        "@types/react-transition-group": "^4.4.12",
        "@types/react-window": "^1.8.8",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.24",
        "electron": "^40.4.0",
        "electron-builder": "^26.8.1",
        "eslint": "^9.39.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^17.3.0",
        "jsdom": "^27.4.0",
        "path-browserify": "^1.0.1",
        "playwright": "^1.58.2",
        "postcss": "^8.5.6",
        "react-window": "^2.2.6",
        "rollup-plugin-visualizer": "^6.0.5",
        "secretlint": "^11.3.1",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "tailwindcss": "^3.4.17",
        "terser": "^5.46.0",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.56.0",
        "vite": "^7.3.1",
        "vite-plugin-electron": "^0.28.0",
        "vite-plugin-electron-renderer": "^0.14.0",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/commands": "^6.10.2",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.10",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.1",
        "@codemirror/lang-markdown": "^6.3.2",
        "@codemirror/lang-python": "^6.2.0",
        "@codemirror/state": "^6.5.4",
        "@codemirror/theme-one-dark": "^6.1.2",
        "@codemirror/view": "^6.39.16",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@floating-ui/react": "^0.27.18",
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@sentry/electron": "^7.9.0",
        "@types/dompurify": "^3.2.0",
        "@types/ssh2": "^1.15.5",
        "@types/ws": "8.18.1",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-webgl": "^0.19.0",
        "@xterm/xterm": "^6.0.0",
        "@xyflow/react": "^12.10.1",
        "axios": "^1.13.5",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "diff": "^8.0.3",
        "dompurify": "^3.3.1",
        "dotenv": "^17.3.1",
        "electron-log": "^5.4.3",
        "electron-updater": "^6.8.3",
        "jose": "^6.1.3",
        "js-tiktoken": "1.0.21",
        "katex": "^0.16.33",
        "lib0": "^0.2.117",
        "lucide-react": "^0.576.0",
        "mermaid": "^10.9.5",
        "monaco-editor": "^0.55.1",
        "node-pty": "^1.1.0",
        "prism-react-renderer": "^2.4.1",
        "re-resizable": "^6.11.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-file-icon": "^1.6.0",
        "react-markdown": "^9.0.0",
        "react-virtuoso": "^4.18.2",
        "rehype-katex": "^7.0.1",
        "remark-gfm": "^4.0.0",
        "remark-math": "^6.0.0",
        "ssh2": "^1.17.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "undici": "^6.19.2",
        "ws": "8.19.0",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0",
        "y-protocols": "^1.0.7",
        "yjs": "^13.6.29",
        "zod": "^4.3.6"
    },
    "build": {
        "appId": "com.tengra.app",
        "productName": "Tengra",
        "executableName": "Tengra",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*"
        ],
        "extraResources": [
            {
                "from": "resources/bin",
                "to": "bin",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "extraFiles": [
            {
                "from": "scripts/register-services.ps1",
                "to": "scripts/register-services.ps1"
            },
            {
                "from": "scripts/install-db-service.ps1",
                "to": "scripts/install-db-service.ps1"
            }
        ],
        "win": {
            "artifactName": "${productName}.${ext}",
            "target": [
                "nsis",
                "portable",
                "zip"
            ],
            "icon": "resources/icon.ico",
            "publisherName": "Tengra Team"
        },
        "nsis": {
            "artifactName": "${productName} Setup.${ext}",
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "include": "build/installer.nsh",
            "uninstallDisplayName": "${productName}",
            "installerIcon": "resources/icon.ico",
            "uninstallerIcon": "resources/icon.ico",
            "installerSidebar": "resources/installer-sidebar.bmp",
            "license": "LICENSE"
        },
        "portable": {
            "artifactName": "${productName} Portable.${ext}"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "category": "Development",
            "icon": "src/renderer/assets/logo.png"
        },
        "publish": {
            "provider": "github",
            "owner": "TengraStudio",
            "repo": "tengra"
        }
    },
    "overrides": {
        "axios": "^1.13.5"
    },
    "optionalDependencies": {
        "bufferutil": "*",
        "utf-8-validate": "*"
    }
}

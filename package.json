{
  "name": "orbit",
  "version": "1.0.0",
  "description": "Orbit - Your Personal AI Assistant",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "set NODE_OPTIONS=--max-old-space-size=8192 && vite",
    "electron:build": "npm run build && electron-builder"
  },
  "keywords": [
    "ai",
    "chat",
    "ollama",
    "electron",
    "copilot",
    "orbit"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",

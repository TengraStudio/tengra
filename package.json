{
  "name": "orbit",
  "version": "1.0.0",
  "description": "Orbit - Your Personal AI Assistant",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE= && set NODE_OPTIONS=--max-old-space-size=8192 && vite",
    "build": "tsc && lint . && vite build && node scripts/build-native.js",
    "build:check": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "setup-build-env": "node scripts/setup-build-env.js",
    "preinstall": "node scripts/setup-build-env.js || true",
    "postinstall": "node scripts/setup-build-env.js || true",
    "install:native": "powershell -ExecutionPolicy Bypass -File scripts/install-native.ps1",
    "electron:dev": "set ELECTRON_RUN_AS_NODE= && set NODE_OPTIONS=--max-old-space-size=8192 && vite",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "lint:boundaries": "node scripts/check-boundaries.js",
    "dead-code": "node scripts/dead-code-detection.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky install || true"
  },
  "keywords": [
    "ai",
    "chat",
    "ollama",
    "electron",
    "copilot",
    "orbit"
  ],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.19.27",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-file-icon": "^1.0.4",
    "@types/react-transition-group": "^4.4.12",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.0",
    "depcheck": "^1.4.7",
    "electron": "^31.7.7",
    "electron-builder": "^24.9.0",
    "electron-playwright-helpers": "^2.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.0.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "react-window": "^2.2.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "tailwindcss": "^3.4.17",
    "terser": "^5.44.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.52.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.0.16",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.10",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/lang-python": "^6.2.0",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.7.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.39.11",
    "@electric-sql/pglite": "^0.3.15",
    "@electron-toolkit/utils": "^4.0.0",
    "@floating-ui/react": "^0.27.16",
    "@monaco-editor/react": "^4.7.0",
    "@primno/dpapi": "^2.0.1",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/electron": "^7.6.0",
    "@types/dompurify": "^3.2.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "8.18.1",
    "@uiw/react-codemirror": "^4.22.2",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.2",
    "monaco-editor": "^0.55.1",
    "monaco-editor-textmate": "^4.0.0",
    "monaco-textmate": "^3.0.1",
    "node-pty": "^1.1.0",
    "os-utils": "^0.0.14",
    "pdf-parse": "^2.4.5",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-file-icon": "^1.6.0",
    "react-katex": "^3.1.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.12.0",
    "react-symbols": "^0.0.6",
    "react-transition-group": "^4.4.5",
    "react-virtuoso": "^4.18.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "undici": "^6.19.2",
    "vscode-oniguruma": "^2.0.1",
    "ws": "8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.orbit.app",
    "productName": "Orbit",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      "resources/bin/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "src/renderer/assets/logo.png",
      "publisherName": "Orbit Team"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "src/renderer/assets/logo.png"
    },
    "publish": {
      "provider": "github",
      "owner": "TengraStudio",
      "repo": "orbit"
    }
  },
  "optionalDependencies": {
    "bufferutil": "*",
    "utf-8-validate": "*"
  }
}

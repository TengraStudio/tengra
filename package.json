{
    "name": "tengra",
    "version": "1.0.0",
    "description": "Tengra - Your Personal AI Assistant",
    "main": "dist/main/main.js",
    "type": "commonjs",
    "overrides": {
        "mermaid": {
            "uuid": "^14.0.0"
        },
        "bash-language-server": {
            "editorconfig": "3.0.2"
        },
        "editorconfig": {
            "minimatch": "10.2.5"
        }
    },
    "scripts": {
        "dev": "node scripts/dev-vite.js",
        "build": "node scripts/build-all.js",
        "build:package": "node scripts/build-all.js --package",
        "build:publish": "node scripts/build-all.js --publish",
        "test": "vitest run",
        "test:unit": "vitest run --config vitest.config.ts",
        "test:renderer": "vitest run --config vitest.config.renderer.ts",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage && vitest run --coverage --config vitest.config.renderer.ts",
        "test:e2e": "playwright test",
        "lint": "npm run lint:eslint && npm run lint:styles",
        "lint:eslint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache",
        "lint:styles": "node scripts/audit-renderer-design.js && npm run lint:stylelint",
        "lint:stylelint": "stylelint \"src/**/*.{css,scss}\"",
        "lint:fix": "npm run lint:eslint -- --fix && npm run lint:stylelint -- --fix",
        "type-check": "tsc --noEmit",
        "verify": "npm run lint && npm run type-check && npm run test",
        "format": "npx prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
        "themes:sync": "node scripts/sync-theme-manifests.js",
        "postinstall": "electron-builder install-app-deps || node -e \"process.exit(0)\"",
        "prepare": "node -e \"try { require('husky').install() } catch (e) { process.exit(0) }\"",
        "audit:deps:gate": "npm audit --audit-level=high"
    },
    "keywords": [
        "ai",
        "chat",
        "ollama",
        "electron",
        "copilot",
        "tengra"
    ],
    "author": "TengraStudio",
    "license": "GPL-3.0",
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@secretlint/secretlint-rule-preset-recommend": "^11.7.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/dompurify": "^3.0.0",
        "@types/mermaid": "^9.1.0",
        "@types/node": "^20.19.39",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.2.0",
        "@types/react-file-icon": "^1.0.5",
        "@types/react-window": "^2.0.0",
        "@types/ssh2": "^1.15.5",
        "@types/uuid": "^10.0.0",
        "@types/ws": "8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitejs/plugin-react": "^4.2.0",
        "@vitejs/plugin-react-oxc": "^0.4.3",
        "autoprefixer": "^10.5.0",
        "electron": "^40.9.1",
        "electron-builder": "^26.8.1",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^17.5.0",
        "husky": "^9.0.0",
        "jsdom": "^27.4.0",
        "lightningcss": "^1.32.0",
        "path-browserify": "^1.0.1",
        "playwright": "^1.58.2",
        "postcss": "^8.5.10",
        "react-window": "^2.2.7",
        "rollup-plugin-visualizer": "^6.0.11",
        "secretlint": "^11.7.1",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "tailwindcss": "^3.4.17",
        "terser": "^5.46.1",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.10",
        "vite-plugin-electron": "^0.29.1",
        "vite-plugin-electron-renderer": "^0.14.0",
        "vitest": "^4.1.4"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@floating-ui/react": "^0.27.19",
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-webgl": "^0.19.0",
        "@xterm/xterm": "^6.0.0",
        "@xyflow/react": "^12.10.2",
        "axios": "^1.13.5",
        "bash-language-server": "^5.6.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "diff": "^8.0.4",
        "discord.js": "^14.26.3",
        "dockerfile-language-server-nodejs": "^0.15.0",
        "dompurify": "^3.4.1",
        "electron-updater": "^6.8.3",
        "jose": "^6.2.2",
        "js-tiktoken": "1.0.21",
        "katex": "^0.16.45",
        "lib0": "^0.2.117",
        "lucide-react": "^0.577.0",
        "mermaid": "^11.14.0",
        "minimatch": "^10.2.5",
        "monaco-editor": "^0.53.0",
        "node-pty": "^1.1.0",
        "pdf-parse": "^1.1.4",
        "prism-react-renderer": "^2.4.1",
        "pyright": "^1.1.409",
        "re-resizable": "^6.11.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-file-icon": "^1.6.0",
        "react-markdown": "^9.0.0",
        "react-virtuoso": "^4.18.5",
        "rehype-katex": "^7.0.1",
        "remark-gfm": "^4.0.0",
        "remark-math": "^6.0.0",
        "ssh2": "^1.17.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "telegraf": "^4.16.3",
        "typescript-language-server": "^5.1.3",
        "undici": "^6.25.0",
        "uuid": "^14.0.0",
        "vscode-jsonrpc": "^8.2.1",
        "vscode-langservers-extracted": "^4.10.0",
        "vscode-languageserver-protocol": "^3.17.5",
        "ws": "8.20.0",
        "y-protocols": "^1.0.7",
        "yaml-language-server": "^1.22.0",
        "yjs": "^13.6.30",
        "zod": "^4.3.6"
    },
    "build": {
        "appId": "com.tengra.app",
        "productName": "Tengra",
        "executableName": "Tengra",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*"
        ],
        "extraFiles": [
            {
                "from": "resources/utility-workers",
                "to": "utility-workers"
            },
            {
                "from": "scripts/tasks/win-services-register.ps1",
                "to": "scripts/tasks/win-services-register.ps1"
            },
            {
                "from": "scripts/tasks/win-db-install.ps1",
                "to": "scripts/tasks/win-db-install.ps1"
            }
        ],
        "win": {
            "artifactName": "${productName}.${ext}",
            "target": [
                "nsis",
                "portable",
                "zip"
            ],
            "icon": "resources/icon.ico"
        },
        "nsis": {
            "artifactName": "${productName} Setup.${ext}",
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "include": "build/installer.nsh",
            "uninstallDisplayName": "${productName}",
            "installerIcon": "resources/icon.ico",
            "uninstallerIcon": "resources/icon.ico",
            "installerSidebar": "resources/installer-sidebar.bmp",
            "license": "LICENSE"
        },
        "portable": {
            "artifactName": "${productName} Portable.${ext}"
        },
        "mac": {
            "artifactName": "${productName}.${ext}",
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.developer-tools",
            "icon": "resources/icon.icns",
            "hardenedRuntime": true,
            "gatekeeperAssess": false
        },
        "dmg": {
            "artifactName": "${productName} Setup.${ext}",
            "contents": [
                {
                    "x": 410,
                    "y": 150,
                    "type": "link",
                    "path": "/Applications"
                },
                {
                    "x": 130,
                    "y": 150,
                    "type": "file"
                }
            ]
        },
        "linux": {
            "target": [
                "AppImage",
                "deb",
                "rpm",
                "zip"
            ],
            "category": "Development",
            "icon": "resources/icon.png"
        },
        "publish": {
            "provider": "github",
            "owner": "TengraStudio",
            "repo": "tengra"
        }
    },
    "optionalDependencies": {
        "bufferutil": "*",
        "utf-8-validate": "*"
    }
}

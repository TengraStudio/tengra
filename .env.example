# OAuth Client Configuration
# These credentials are used for third-party service authentication

# Antigravity API - Main application credentials
ANTIGRAVITY_CLIENT_ID=
ANTIGRAVITY_CLIENT_SECRET=

# Antigravity SDK - SDK-specific credentials
ANTIGRAVITY_SDK_CLIENT_ID=
ANTIGRAVITY_SDK_CLIENT_SECRET=

# Google Gemini OAuth - For Gemini AI model access
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=

# iFlow - Workflow automation service
IFLOW_CLIENT_ID=
IFLOW_CLIENT_SECRET=

# Qwen (Alibaba Cloud) - Chinese LLM provider
QWEN_CLIENT_ID=

# OpenAI OAuth - For ChatGPT/GPT-4 API access
OPENAI_OAUTH_CLIENT_ID=

# Anthropic OAuth - For Claude API access
ANTHROPIC_OAUTH_CLIENT_ID=

# Gemini CLI - Command-line interface credentials
GEMINI_CLI_CLIENT_ID=
GEMINI_CLI_CLIENT_SECRET=

# Tavily API - Web search and research API
TAVILY_API_KEY=

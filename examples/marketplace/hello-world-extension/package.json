{
    "name": "hello-world-extension",
    "version": "1.0.0",
    "description": "A minimal Hello World extension for Tengra.",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w"
    },
    "keywords": [],
    "author": "Tengra Team",
    "license": "MIT",
    "devDependencies": {
        "typescript": "^5.0.0"
    },
    "tengra": {
